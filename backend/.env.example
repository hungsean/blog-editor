# Server
PORT=3000

# Database
DB_PATH=../data/blog-editor.db

# GitHub
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# App
NODE_ENV=development
PR_CHECK_INTERVAL_MS=60000

# CORS：逗號分隔的允許來源；留空則預設只放行 localhost 開發來源。
# docker 部署由 nginx 同源代理 /api，通常不需設定。
CORS_ORIGIN=
