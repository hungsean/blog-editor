GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-blog-repo
GITHUB_DEFAULT_BRANCH=main
PORT=3000
# DB_PATH=/data/blog-editor.db

# AI Translation (optional)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com  # override for compatible APIs (e.g. Azure, local)

# Image Upload — Cloudflare R2 (optional)
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=your-bucket-name
# R2_PUBLIC_URL=https://images.yourdomain.com  # custom domain bound to the R2 bucket
