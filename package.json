{
  "name": "blog-editor",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:editor": "bun build public/js/editor.src.js --outfile public/js/editor.bundle.js --target browser --minify",
    "watch:editor": "bun build public/js/editor.src.js --outfile public/js/editor.bundle.js --target browser --watch",
    "dev": "bun --hot index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "hono": "^4.12.12",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.4",
    "nanoid": "^5.1.7"
  }
}
